  "components": {
    "schemas": {
      "CreateChambreDto": {
        "required": [
          "numChambre",
          "type",
          "etage",
          "capaciteAccueil",
          "description",
          "equipementIds"
        ],
        "type": "object",
        "properties": {
          "numChambre": {
            "type": "string"
          },
          "type": {
            "$ref": "#/components/schemas/TypeChambre"
          },
          "etage": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "capaciteAccueil": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "description": {
            "type": [
              "null",
              "string"
            ]
          },
          "equipementIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          }
        }
      },
      "CreateClientDto": {
        "required": [
          "nom",
          "prenom",
          "numPieceIdentite",
          "numeroTelephone",
          "email",
